# Jzero Configuration
# Copy this file to .env and adjust settings for your environment

# === Server Settings ===
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=*

# === Logging ===
LOG_LEVEL=INFO
LOG_STACK=false
NO_COLOR=false

# === Ephemeris and Calculations ===
EPHEMERIS_DATA_PATH=./data
SWISS_EPHEMERIS=false

# === API Settings ===
API_MAX_REQUEST_SIZE=10mb
API_TIMEOUT=30000

# === Caching ===
CACHE_ENABLED=true
CACHE_TTL=3600

# === Rate Limiting ===
RATE_LIMIT=false
RATE_LIMIT_WINDOW=900000

# === Database ===
DATABASE_TYPE=memory
DATABASE_PATH=./data/charts.db

# === Optional: Database URLs for PostgreSQL/MongoDB ===
# DATABASE_URL=postgresql://user:password@localhost/jzero
# DATABASE_URL=mongodb://localhost/jzero

# === Feature Flags ===
# FEATURE_BIRTH_CHART=true
# FEATURE_TRANSITS=true
# FEATURE_SYNASTRY=true
# FEATURE_PROGRESSIONS=true
# FEATURE_REPORTS=true
