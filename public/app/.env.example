# Frontend Environment Variables
# Copy this file to .env.local and adjust as needed

# API Configuration
VITE_API_BASE_URL=http://localhost:5000/api

# App Configuration
VITE_APP_TITLE=Jzero - Astrology Birth Chart Calculator
VITE_APP_DESCRIPTION=Professional astrology birth chart calculations powered by Swiss Ephemeris

# Feature Flags
VITE_ENABLE_SYNASTRY=false
VITE_ENABLE_PROGRESSIONS=false
VITE_ENABLE_TRANSITS=true

# Logger Configuration
VITE_LOG_LEVEL=info
